# --- Python & Environment ---
.venv/
env/
__pycache__/
*.pyc
.python-version

# --- Package Management (uv) ---
# We keep uv.lock and pyproject.toml, but ignore the tool's cache
.uv/

# --- Database & Storage (Local Only) ---
# We ignore the database files but keep the data folder structure
data/*.db
data/*.sqlite
# Mandatory: Ensure the threat framework is NOT ignored
!data/threat_frameworks.json

# --- Security & Secrets ---
# NEVER push these files to GitHub
.env
*.session
secrets.json

# --- OS Specific ---
.DS_Store
Thumbs.db