# --- PROXIMA-GEN Configuration Example ---
# Instructions: Copy this file to '.env' and fill in your actual keys.

# AI Framework API Keys
TAVILY_API_KEY=your_tavily_api_key_here
GITHUB_TOKEN=your_github_pat_here

# Local Inference Engine (Ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Optional: Telegram Bot Credentials
TELEGRAM_API_ID=your_id_here
TELEGRAM_API_HASH=your_hash_here